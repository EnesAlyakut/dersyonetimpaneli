@model OgrenciDersYonetim.Web.Models.ViewModels.ProfilViewModel
@{
    ViewData["Title"] = "Profilim";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <div class="avatar-lg" style="width:50px;height:50px;background:linear-gradient(135deg,#4f46e5,#06b6d4);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:1.2rem;">
                @Model.Ad.Substring(0, 1)@Model.Soyad.Substring(0, 1)
            </div>
            <div>
                <h1 class="page-title">@Model.Ad @Model.Soyad</h1>
                <p class="page-subtitle">@Model.KullaniciAdi · <span class="role-badge @Model.Rol.ToLower()">@Model.Rol</span></p>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row g-4">
        <!-- Profil Bilgileri -->
        <div class="col-lg-7">
            <form asp-action="Profil" method="post" id="profilForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="KullaniciAdi" />
                <input type="hidden" asp-for="Rol" />
                <input type="hidden" asp-for="KayitTarihi" />

                <div class="form-card mb-4">
                    <h6 class="fw-bold mb-4"><i class="bi bi-person-fill me-2 text-primary"></i>Kişisel Bilgiler</h6>
                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="Ad" class="form-label"></label>
                            <input asp-for="Ad" class="form-control" id="txtAd" />
                            <span asp-validation-for="Ad" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Soyad" class="form-label"></label>
                            <input asp-for="Soyad" class="form-control" id="txtSoyad" />
                            <span asp-validation-for="Soyad" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" id="txtEmail" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="form-card mb-4">
                    <h6 class="fw-bold mb-4"><i class="bi bi-lock-fill me-2 text-warning"></i>Şifre Değiştir <small class="text-muted fw-normal">(İsteğe Bağlı)</small></h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="MevcutSifre" class="form-label"></label>
                            <input asp-for="MevcutSifre" type="password" class="form-control" id="txtMevcutSifre" />
                            <span asp-validation-for="MevcutSifre" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="YeniSifre" class="form-label"></label>
                            <input asp-for="YeniSifre" type="password" class="form-control" id="txtYeniSifre" />
                            <span asp-validation-for="YeniSifre" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="YeniSifreTekrar" class="form-label"></label>
                            <input asp-for="YeniSifreTekrar" type="password" class="form-control" id="txtYeniSifreTekrar" />
                            <span asp-validation-for="YeniSifreTekrar" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" id="btnKaydet">
                        <i class="bi bi-check-circle me-2"></i>Değişiklikleri Kaydet
                    </button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                </div>
            </form>
        </div>

        <!-- Hesap Bilgileri -->
        <div class="col-lg-5">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-info-circle me-2 text-primary"></i>Hesap Bilgileri
                </div>
                <div class="card-body">
                    <div class="detail-item">
                        <div class="detail-icon"><i class="bi bi-person"></i></div>
                        <div>
                            <div class="detail-label">Kullanıcı Adı</div>
                            <div class="detail-value">@@Model.KullaniciAdi</div>
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-icon"><i class="bi bi-shield"></i></div>
                        <div>
                            <div class="detail-label">Rol</div>
                            <div class="detail-value"><span class="role-badge @Model.Rol.ToLower()">@Model.Rol</span></div>
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-icon"><i class="bi bi-calendar"></i></div>
                        <div>
                            <div class="detail-label">Kayıt Tarihi</div>
                            <div class="detail-value">@Model.KayitTarihi.ToString("dd.MM.yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mt-3 border-danger">
                <div class="card-body text-center p-4">
                    <i class="bi bi-box-arrow-right text-danger" style="font-size:2rem;"></i>
                    <p class="mt-2 mb-3 text-muted small">Oturumu sonlandırmak için çıkış yapınız.</p>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger w-100" id="btnCikis">
                        <i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
