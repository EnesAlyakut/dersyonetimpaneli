@model List<OgrenciDersYonetim.Core.Entities.OgrenciDers>
@{
    ViewData["Title"] = "Ders Detay - Kayıtlı Öğrenciler";
    var ders = ViewBag.Ders as OgrenciDersYonetim.Core.Entities.Ders;
    var rol = ViewBag.Rol as string;
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Geri
                </a>
                <div>
                    <h1 class="page-title"><i class="bi bi-people-fill me-2 text-primary"></i>@ders?.DersAdi — Kayıtlı Öğrenciler</h1>
                    <p class="page-subtitle">
                        <span class="ogrenci-no">@ders?.DersKodu</span>
                        &nbsp;·&nbsp;@Model.Count öğrenci kayıtlı
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="table-wrapper">
        @if (Model.Any())
        {
            <table class="table" id="tblDersOgrenciler">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Ad Soyad</th>
                        <th>Öğrenci No</th>
                        <th>Atama Tarihi</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var od = Model[i];
                        <tr>
                            <td class="text-muted">@(i+1)</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-sm" style="width:32px;height:32px;font-size:0.7rem;">
                                        @od.Ogrenci.Ad.Substring(0, 1)@od.Ogrenci.Soyad.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@od.Ogrenci.Ad @od.Ogrenci.Soyad</div>
                                        <small class="text-muted">@od.Ogrenci.Email</small>
                                    </div>
                                </div>
                            </td>
                            <td><span class="ogrenci-no">@od.Ogrenci.OgrenciNo</span></td>
                            <td class="text-muted small">@od.AtamaTarihi.ToString("dd.MM.yyyy")</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-controller="Ogrenci" asp-action="Detay" asp-route-id="@od.OgrenciId"
                                       class="btn btn-sm btn-outline-primary" title="Öğrenci Detayı" id="btnOgrDetay_@od.OgrenciId">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (rol == "Admin" || rol == "Ogretmen")
                                    {
                                        <a asp-controller="Not" asp-action="Ekle"
                                           asp-route-ogrenciId="@od.OgrenciId" asp-route-dersId="@ders?.Id"
                                           class="btn btn-sm btn-success" title="Not Ekle" id="btnNotEkle_@od.OgrenciId">
                                            <i class="bi bi-journal-plus me-1"></i>Not Ekle
                                        </a>
                                        <a asp-controller="Devamsizlik" asp-action="Ekle"
                                           asp-route-ogrenciId="@od.OgrenciId" asp-route-dersId="@ders?.Id"
                                           class="btn btn-sm btn-danger" title="Devamsızlık Ekle" id="btnDevEkle_@od.OgrenciId">
                                            <i class="bi bi-calendar-x me-1"></i>Devamsızlık
                                        </a>
                                        <a asp-controller="Not" asp-action="OgrenciNot" asp-route-ogrenciId="@od.OgrenciId"
                                           class="btn btn-sm btn-outline-success" title="Tüm Notlar" id="btnNotGor_@od.OgrenciId">
                                            <i class="bi bi-list-check"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-people"></i>
                <h5>Kayıtlı Öğrenci Yok</h5>
                <p class="small">Bu derse henüz öğrenci atanmamış.</p>
                @if (rol == "Admin" || rol == "Ogretmen")
                {
                    <a asp-controller="Atama" asp-action="Index" class="btn btn-primary mt-2" id="btnAtamaGit">
                        <i class="bi bi-person-plus me-2"></i>Öğrenci Ata
                    </a>
                }
            </div>
        }
    </div>
</div>
