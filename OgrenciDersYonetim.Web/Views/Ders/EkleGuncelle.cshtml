@model OgrenciDersYonetim.Core.Entities.Ders
@{
    ViewData["Title"] = Model.Id == 0 ? "Ders Ekle" : "Ders Guncelle";
    var isEdit = Model.Id != 0;
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Geri
            </a>
            <div>
                <h1 class="page-title">
                    @if (isEdit)
                    {
                        <i class="bi bi-pencil-fill me-2 text-warning"></i>
                        <span>Ders Guncelle</span>
                    }
                    else
                    {
                        <i class="bi bi-journal-plus me-2 text-primary"></i>
                        <span>Yeni Ders Ekle</span>
                    }
                </h1>
                <p class="page-subtitle">@(isEdit ? "Ders bilgilerini duzenleyin" : "Yeni ders olusturun")</p>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <form asp-action="EkleGuncelle" method="post" id="dersForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="EklenmeTarihi" />

                <div class="form-card">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="DersAdi" class="form-label"><i class="bi bi-book me-1"></i>Ders Adi</label>
                            <input asp-for="DersAdi" class="form-control" placeholder="Ornek: Matematik" id="txtDersAdi" />
                            <span asp-validation-for="DersAdi" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DersKodu" class="form-label"><i class="bi bi-hash me-1"></i>Ders Kodu</label>
                            <input asp-for="DersKodu" class="form-control" placeholder="MAT101" id="txtDersKodu" style="text-transform:uppercase;" />
                            <span asp-validation-for="DersKodu" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Kredi" class="form-label"><i class="bi bi-star me-1"></i>Kredi</label>
                            <input asp-for="Kredi" type="number" class="form-control" min="1" max="10" id="txtKredi" />
                            <span asp-validation-for="Kredi" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Ogretmen" class="form-label"><i class="bi bi-person-badge me-1"></i>Ogretmen</label>
                            <input asp-for="Ogretmen" class="form-control" placeholder="Prof. Dr. Ali Veli" id="txtOgretmen" />
                            <span asp-validation-for="Ogretmen" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Aciklama" class="form-label"><i class="bi bi-text-left me-1"></i>Aciklama</label>
                            <textarea asp-for="Aciklama" class="form-control" rows="3" placeholder="Ders hakkinda kisa aciklama..." id="txtAciklama"></textarea>
                            <span asp-validation-for="Aciklama" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn @(isEdit ? "btn-warning" : "btn-primary")" id="btnDersKaydet">
                            <i class="bi bi-check-circle me-2"></i>@(isEdit ? "Guncelle" : "Kaydet")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Iptal</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Ders kodunu otomatik buyuk harfe cevir
        document.getElementById('txtDersKodu').addEventListener('input', function () {
            this.value = this.value.toUpperCase();
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
