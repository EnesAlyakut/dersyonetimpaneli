@model List<OgrenciDersYonetim.Core.Entities.Ders>
@{
    ViewData["Title"] = "Ders Listesi";
    var rol = ViewBag.Rol as string;
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <h1 class="page-title"><i class="bi bi-book-fill me-2 text-info"></i>Dersler</h1>
                <p class="page-subtitle">Sistemdeki tum dersler</p>
            </div>
            @if (rol == "Admin")
            {
                <a asp-action="Ekle" class="btn btn-primary" id="btnDersEkle">
                    <i class="bi bi-journal-plus me-2"></i>Yeni Ders
                </a>
            }
        </div>
    </div>
</div>

<div class="container">
    <div class="table-wrapper">
        @if (Model.Any())
        {
            <table class="table" id="tblDersler">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Ders Adi</th>
                        <th>Ders Kodu</th>
                        <th>Kredi</th>
                        <th>Ogretmen</th>
                        <th>Ogrenci Sayisi</th>
                        <th class="text-end">Islemler</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var ders = Model[i];
                        <tr>
                            <td class="text-muted">@(i + 1)</td>
                            <td>
                                <div class="fw-semibold">@ders.DersAdi</div>
                                @if (!string.IsNullOrEmpty(ders.Aciklama))
                                {
                                    <small class="text-muted">@(ders.Aciklama.Length > 50 ? ders.Aciklama.Substring(0, 50) + "..." : ders.Aciklama)</small>
                                }
                            </td>
                            <td><span class="ogrenci-no">@ders.DersKodu</span></td>
                            <td><span class="badge bg-info text-white">@ders.Kredi</span></td>
                            <td class="text-muted small">@(ders.Ogretmen ?? "-")</td>
                            <td>
                                <a asp-controller="Atama" asp-action="DersDetay" asp-route-dersId="@ders.Id" class="badge bg-primary rounded-pill text-decoration-none">
                                    @ders.OgrenciDersler.Count ogrenci
                                </a>
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Detay" asp-route-id="@ders.Id" class="btn btn-sm btn-outline-primary" title="Detay">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (rol == "Admin")
                                    {
                                        <a asp-action="Guncelle" asp-route-id="@ders.Id" class="btn btn-sm btn-outline-warning" title="Düzenle">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                    @if (rol == "Admin")
                                    {
                                        <form asp-action="Sil" method="post" style="display:inline;" onsubmit="return confirm('@ders.DersAdi dersini silmek istediginizden emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@ders.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-journal-x"></i>
                <h5>Ders Bulunamadi</h5>
                <p class="small">Henuz ders eklenmemis.</p>
                @if (rol == "Admin")
                {
                    <a asp-action="Ekle" class="btn btn-primary mt-2">
                        <i class="bi bi-journal-plus me-2"></i>Ders Ekle
                    </a>
                }
            </div>
        }
    </div>
</div>
