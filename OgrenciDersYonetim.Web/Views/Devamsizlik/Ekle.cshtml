@model OgrenciDersYonetim.Core.Entities.Devamsizlik
@{
    ViewData["Title"] = "Devamsızlık Ekle";
    var ogrenci = ViewBag.Ogrenci as OgrenciDersYonetim.Core.Entities.Ogrenci;
    var dersler = ViewBag.Dersler as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="OgrenciDevamsizlik" asp-route-ogrenciId="@Model.OgrenciId" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Geri
            </a>
            <div>
                <h1 class="page-title"><i class="bi bi-calendar-x me-2 text-danger"></i>Devamsızlık Ekle</h1>
                <p class="page-subtitle">@ogrenci?.Ad @ogrenci?.Soyad için devamsızlık kaydı</p>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body p-4">
                    <form asp-action="Ekle" method="post" id="frmDevamsizlikEkle">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="OgrenciId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="DersId" class="form-label fw-semibold">Ders <span class="text-danger">*</span></label>
                                <select asp-for="DersId" asp-items="dersler" class="form-select" id="selectDevamsizlikDers">
                                    <option value="">-- Ders Seçin --</option>
                                </select>
                                <span asp-validation-for="DersId" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Tarih" class="form-label fw-semibold">Devamsızlık Tarihi <span class="text-danger">*</span></label>
                                <input asp-for="Tarih" type="date" class="form-control" id="inputDevamsizlikTarih" />
                                <span asp-validation-for="Tarih" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Aciklama" class="form-label fw-semibold">Açıklama</label>
                                <textarea asp-for="Aciklama" class="form-control" rows="2"
                                          placeholder="Opsiyonel (örn: hastalık, mazeret...)" id="inputDevamsizlikAciklama"></textarea>
                                <span asp-validation-for="Aciklama" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-danger" id="btnDevamsizlikEkleKaydet">
                                <i class="bi bi-check-circle me-2"></i>Kaydet
                            </button>
                            <a asp-action="OgrenciDevamsizlik" asp-route-ogrenciId="@Model.OgrenciId" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>İptal
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
