@model OgrenciDersYonetim.Core.Entities.Ogretmen
@{
    ViewData["Title"] = "Öğretmen Ekle";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Geri
            </a>
            <div>
                <h1 class="page-title"><i class="bi bi-person-plus-fill me-2 text-primary"></i>Yeni Öğretmen Ekle</h1>
                <p class="page-subtitle">Sisteme yeni öğretmen ekleyin</p>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-4">
                    <form asp-action="Ekle" method="post" id="frmOgretmenEkle">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Ad" class="form-label fw-semibold">Ad <span class="text-danger">*</span></label>
                                <input asp-for="Ad" class="form-control" placeholder="Öğretmenin adı" id="inputOgretmenAd" />
                                <span asp-validation-for="Ad" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Soyad" class="form-label fw-semibold">Soyad <span class="text-danger">*</span></label>
                                <input asp-for="Soyad" class="form-control" placeholder="Öğretmenin soyadı" id="inputOgretmenSoyad" />
                                <span asp-validation-for="Soyad" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Brans" class="form-label fw-semibold">Branş</label>
                                <input asp-for="Brans" class="form-control" placeholder="Örn: Matematik, Fizik" id="inputBrans" />
                                <span asp-validation-for="Brans" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Telefon" class="form-label fw-semibold">Telefon</label>
                                <input asp-for="Telefon" class="form-control" placeholder="05xx xxx xx xx" id="inputOgretmenTelefon" />
                                <span asp-validation-for="Telefon" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Email" class="form-label fw-semibold">E-posta</label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="ogretmen@okul.edu.tr" id="inputOgretmenEmail" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary" id="btnOgretmenEkleKaydet">
                                <i class="bi bi-check-circle me-2"></i>Kaydet
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>İptal
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
