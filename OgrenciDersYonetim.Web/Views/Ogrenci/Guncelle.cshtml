@model OgrenciDersYonetim.Core.Entities.Ogrenci
@{
    ViewData["Title"] = "Ogrenci Guncelle";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Geri
            </a>
            <div>
                <h1 class="page-title"><i class="bi bi-pencil-fill me-2 text-warning"></i>Ogrenci Guncelle</h1>
                <p class="page-subtitle">@Model.Ad @Model.Soyad bilgilerini duzenleyin</p>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <form asp-action="Guncelle" method="post" id="ogrenciGuncelleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="KayitTarihi" />

                <div class="form-card">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Ad" class="form-label"><i class="bi bi-person me-1"></i>Ad</label>
                            <input asp-for="Ad" class="form-control" id="txtAd" />
                            <span asp-validation-for="Ad" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Soyad" class="form-label">Soyad</label>
                            <input asp-for="Soyad" class="form-control" id="txtSoyad" />
                            <span asp-validation-for="Soyad" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OgrenciNo" class="form-label"><i class="bi bi-hash me-1"></i>Ogrenci No</label>
                            <input asp-for="OgrenciNo" class="form-control" id="txtOgrenciNo" />
                            <span asp-validation-for="OgrenciNo" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefon" class="form-label"><i class="bi bi-telephone me-1"></i>Telefon</label>
                            <input asp-for="Telefon" class="form-control" id="txtTelefon" />
                            <span asp-validation-for="Telefon" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>E-posta</label>
                            <input asp-for="Email" class="form-control" id="txtEmail" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-warning" id="btnGuncelle">
                            <i class="bi bi-check-circle me-2"></i>Guncelle
                        </button>
                        <a asp-action="Detay" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Iptal</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
