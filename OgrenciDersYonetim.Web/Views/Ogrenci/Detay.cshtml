@model OgrenciDersYonetim.Core.Entities.Ogrenci
@{
    ViewData["Title"] = "Öğrenci Detay";
    var rol = ViewBag.Rol as string;
    var notlar = ViewBag.Notlar as List<OgrenciDersYonetim.Core.Entities.Not> ?? new();
    var devamsizliklar = ViewBag.Devamsizliklar as List<OgrenciDersYonetim.Core.Entities.Devamsizlik> ?? new();
    var toplamDevamsizlik = (int)(ViewBag.ToplamDevamsizlik ?? 0);
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Geri
            </a>
            <div>
                <h1 class="page-title"><i class="bi bi-person-circle me-2 text-primary"></i>@Model.Ad @Model.Soyad</h1>
                <p class="page-subtitle">Öğrenci No: @Model.OgrenciNo</p>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row g-4">
        <!-- Öğrenci Bilgileri (Sol Kolon) -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body text-center p-4">
                    <div class="avatar-sm mx-auto mb-3" style="width:72px;height:72px;font-size:1.6rem;">
                        @Model.Ad.Substring(0, 1)@Model.Soyad.Substring(0, 1)
                    </div>
                    <h5 class="fw-bold">@Model.Ad @Model.Soyad</h5>
                    <span class="ogrenci-no">@Model.OgrenciNo</span>
                </div>
                <div class="card-body border-top pt-3">
                    <div class="detail-item">
                        <div class="detail-icon"><i class="bi bi-envelope"></i></div>
                        <div>
                            <div class="detail-label">E-posta</div>
                            <div class="detail-value">@(Model.Email ?? "-")</div>
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-icon"><i class="bi bi-telephone"></i></div>
                        <div>
                            <div class="detail-label">Telefon</div>
                            <div class="detail-value">@(Model.Telefon ?? "-")</div>
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-icon"><i class="bi bi-calendar"></i></div>
                        <div>
                            <div class="detail-label">Kayıt Tarihi</div>
                            <div class="detail-value">@Model.KayitTarihi.ToString("dd.MM.yyyy")</div>
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-icon"><i class="bi bi-journal-bookmark"></i></div>
                        <div>
                            <div class="detail-label">Toplam Ders</div>
                            <div class="detail-value">@Model.OgrenciDersler.Count ders</div>
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="detail-icon"><i class="bi bi-calendar-x text-danger"></i></div>
                        <div>
                            <div class="detail-label">Toplam Devamsızlık</div>
                            <div class="detail-value">
                                <span class="badge @(toplamDevamsizlik >= 7 ? "bg-danger" : toplamDevamsizlik >= 4 ? "bg-warning text-dark" : "bg-success")">
                                    @toplamDevamsizlik gün
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                @if (rol == "Admin")
                {
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-action="Guncelle" asp-route-id="@Model.Id" class="btn btn-warning btn-sm flex-fill" id="btnDetayGuncelle">
                            <i class="bi bi-pencil me-1"></i>Düzenle
                        </a>
                        <a asp-controller="Atama" asp-action="Index" asp-route-ogrenciId="@Model.Id"
                           class="btn btn-info btn-sm flex-fill text-white" id="btnDetayAtama">
                            <i class="bi bi-link-45deg me-1"></i>Ders Ata
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- Sağ Kolon - Tablar -->
        <div class="col-lg-8">
            <ul class="nav nav-tabs mb-3" id="ogrenciTab" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="dersler-tab" data-bs-toggle="tab" data-bs-target="#dersler" type="button">
                        <i class="bi bi-book-fill me-1"></i>Dersler
                        <span class="badge bg-primary ms-1">@Model.OgrenciDersler.Count</span>
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="notlar-tab" data-bs-toggle="tab" data-bs-target="#notlar" type="button">
                        <i class="bi bi-journal-check me-1"></i>Notlar
                        <span class="badge bg-success ms-1">@notlar.Count</span>
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="devamsizlik-tab" data-bs-toggle="tab" data-bs-target="#devamsizlik" type="button">
                        <i class="bi bi-calendar-x me-1"></i>Devamsızlık
                        <span class="badge @(toplamDevamsizlik >= 7 ? "bg-danger" : "bg-secondary") ms-1">@toplamDevamsizlik</span>
                    </button>
                </li>
            </ul>

            <div class="tab-content">
                <!-- Dersler Tab -->
                <div class="tab-pane fade show active" id="dersler">
                    <div class="card">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <span><i class="bi bi-book-fill me-2 text-primary"></i>Aldığı Dersler</span>
                            @if (rol == "Admin")
                            {
                                <a asp-controller="Atama" asp-action="Index" asp-route-ogrenciId="@Model.Id"
                                   class="btn btn-sm btn-outline-info" id="btnDersAtaGit">
                                    <i class="bi bi-plus-circle me-1"></i>Ders Ekle
                                </a>
                            }
                        </div>
                        <div class="card-body">
                            @if (Model.OgrenciDersler.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table mb-0" id="tblOgrenciDersler">
                                        <thead>
                                            <tr>
                                                <th>Ders Adı</th>
                                                <th>Kod</th>
                                                <th>Kredi</th>
                                                <th>Atama Tarihi</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var od in Model.OgrenciDersler)
                                            {
                                                <tr>
                                                    <td class="fw-semibold">@od.Ders.DersAdi</td>
                                                    <td><span class="ogrenci-no">@od.Ders.DersKodu</span></td>
                                                    <td><span class="badge bg-info text-white">@od.Ders.Kredi Kredi</span></td>
                                                    <td class="text-muted small">@od.AtamaTarihi.ToString("dd.MM.yyyy")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                <div class="mt-3 p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted small">Toplam Kredi Yükü</span>
                                        <span class="fw-bold text-primary fs-5">@Model.OgrenciDersler.Sum(od => od.Ders.Kredi) Kredi</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="empty-state py-3">
                                    <i class="bi bi-journal-x"></i>
                                    <h6>Henüz Ders Atanmamış</h6>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Notlar Tab -->
                <div class="tab-pane fade" id="notlar">
                    <div class="card">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <span><i class="bi bi-journal-check me-2 text-success"></i>Not Kayıtları</span>
                        </div>
                        <div class="card-body">
                            @if (notlar.Any() || Model.OgrenciDersler.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table mb-0" id="tblDetayNotlar">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Ders</th>
                                                <th class="text-center">Vize <small class="text-muted">(%40)</small></th>
                                                <th class="text-center">Final <small class="text-muted">(%60)</small></th>
                                                <th class="text-center">Ortalama</th>
                                                <th class="text-center">Durum</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var od in Model.OgrenciDersler)
                                            {
                                                var dersNotlari = notlar.Where(n => n.DersId == od.DersId).ToList();
                                                var vizeNotu = dersNotlari.Where(n => n.NotTuru == "Vize").Select(n => n.NotDegeri).LastOrDefault();
                                                var finalNotu = dersNotlari.Where(n => n.NotTuru == "Final").Select(n => n.NotDegeri).LastOrDefault();
                                                var vizVar = dersNotlari.Any(n => n.NotTuru == "Vize");
                                                var finVar = dersNotlari.Any(n => n.NotTuru == "Final");

                                                double? ort = null;
                                                if (vizVar && finVar)
                                                    ort = vizeNotu * 0.4 + finalNotu * 0.6;
                                                else if (vizVar)
                                                    ort = vizeNotu;
                                                else if (finVar)
                                                    ort = finalNotu;

                                                var gecti = ort.HasValue && ort.Value >= 50;
                                                var ortClass = ort == null ? "secondary" : ort >= 85 ? "success" : ort >= 50 ? "warning" : "danger";

                                                <tr>
                                                    <td class="fw-semibold">@od.Ders.DersAdi</td>
                                                    <td class="text-center">
                                                        @if (vizVar)
                                                        {
                                                            <span class="badge bg-info text-white fs-6">@vizeNotu</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted small">-</span>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        @if (finVar)
                                                        {
                                                            <span class="badge bg-primary fs-6">@finalNotu</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted small">-</span>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        @if (ort.HasValue)
                                                        {
                                                            <span class="badge bg-@ortClass fs-6">@ort.Value.ToString("F1")</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted small">-</span>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        @if (ort.HasValue)
                                                        {
                                                            <span class="badge @(gecti ? "bg-success" : "bg-danger") fs-6">
                                                                <i class="bi @(gecti ? "bi-check-circle" : "bi-x-circle") me-1"></i>
                                                                @(gecti ? "GEÇTİ" : "KALDI")
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-light text-muted">Beklemede</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="empty-state py-3">
                                    <i class="bi bi-journal-x"></i>
                                    <h6>Not Kaydı Yok</h6>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Devamsızlık Tab -->
                <div class="tab-pane fade" id="devamsizlik">
                    <div class="card">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <span>
                                <i class="bi bi-calendar-x me-2 text-danger"></i>Devamsızlık Kayıtları
                                <span class="badge @(toplamDevamsizlik >= 7 ? "bg-danger" : toplamDevamsizlik >= 4 ? "bg-warning text-dark" : "bg-secondary") ms-1">
                                    @toplamDevamsizlik gün
                                </span>
                            </span>
                            @if (rol == "Admin" || rol == "Ogretmen")
                            {
                                <a asp-controller="Devamsizlik" asp-action="OgrenciDevamsizlik" asp-route-ogrenciId="@Model.Id"
                                   class="btn btn-sm btn-outline-danger" id="btnDevamsizlikYonetim">
                                    <i class="bi bi-pencil-square me-1"></i>Devamsızlık Yönetimi
                                </a>
                            }
                        </div>
                        <div class="card-body">
                            @if (devamsizliklar.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table mb-0" id="tblDetayDevamsizlik">
                                        <thead>
                                            <tr>
                                                <th>Ders</th>
                                                <th>Tarih</th>
                                                <th>Açıklama</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var dev in devamsizliklar)
                                            {
                                                <tr>
                                                    <td class="fw-semibold">@dev.Ders.DersAdi</td>
                                                    <td>
                                                        <span class="badge bg-danger">
                                                            <i class="bi bi-calendar-x me-1"></i>@dev.Tarih.ToString("dd.MM.yyyy")
                                                        </span>
                                                    </td>
                                                    <td class="text-muted small">@(dev.Aciklama ?? "-")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="empty-state py-3">
                                    <i class="bi bi-calendar-check"></i>
                                    <h6>Devamsızlık Kaydı Yok</h6>
                                    @if (rol == "Admin" || rol == "Ogretmen")
                                    {
                                        <a asp-controller="Devamsizlik" asp-action="Ekle" asp-route-ogrenciId="@Model.Id"
                                           class="btn btn-danger btn-sm mt-2">
                                            <i class="bi bi-plus-circle me-1"></i>Devamsızlık Ekle
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
