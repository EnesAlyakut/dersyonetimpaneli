@model List<OgrenciDersYonetim.Core.Entities.Not>
@{
    ViewData["Title"] = "Öğrenci Notları";
    var ogrenci = ViewBag.Ogrenci as OgrenciDersYonetim.Core.Entities.Ogrenci;
    var dersler = ViewBag.Dersler as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
    var rol = ViewBag.Rol as string;
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <a asp-controller="Ogrenci" asp-action="Detay" asp-route-id="@ogrenci?.Id" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Geri
                </a>
                <div>
                    <h1 class="page-title"><i class="bi bi-journal-check me-2 text-success"></i>@ogrenci?.Ad @ogrenci?.Soyad - Notları</h1>
                    <p class="page-subtitle">Öğrenci No: @ogrenci?.OgrenciNo</p>
                </div>
            </div>
            <a asp-action="Ekle" asp-route-ogrenciId="@ogrenci?.Id" class="btn btn-success" id="btnNotEkle">
                <i class="bi bi-plus-circle me-2"></i>Not Ekle
            </a>
        </div>
    </div>
</div>

<div class="container">
    @if (Model.Any())
    {
        <!-- Özet Kartlar -->
        <div class="row g-3 mb-4">
            @foreach (var dersGrubu in Model.GroupBy(n => n.Ders))
            {
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold small">@dersGrubu.Key.DersAdi</span>
                                <span class="ogrenci-no">@dersGrubu.Key.DersKodu</span>
                            </div>
                            @{
                                var ortalama = dersGrubu.Average(n => n.NotDegeri);
                                var ortalamaClass = ortalama >= 85 ? "success" : ortalama >= 70 ? "warning" : "danger";
                            }
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-@ortalamaClass fs-6">@ortalama.ToString("F1")</span>
                                <small class="text-muted">Ortalama (@dersGrubu.Count() not)</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="table-wrapper">
            <table class="table" id="tblNotlar">
                <thead>
                    <tr>
                        <th>Ders</th>
                        <th>Not Türü</th>
                        <th>Not</th>
                        <th>Tarih</th>
                        <th>Açıklama</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var not in Model)
                    {
                        var notClass = not.NotDegeri >= 85 ? "success" : not.NotDegeri >= 70 ? "warning" : "danger";
                        <tr>
                            <td>
                                <div class="fw-semibold">@not.Ders.DersAdi</div>
                                <small class="text-muted">@not.Ders.DersKodu</small>
                            </td>
                            <td><span class="badge bg-secondary">@not.NotTuru</span></td>
                            <td><span class="badge bg-@notClass fs-6">@not.NotDegeri</span></td>
                            <td class="text-muted small">@not.Tarih.ToString("dd.MM.yyyy")</td>
                            <td class="text-muted small">@(not.Aciklama ?? "-")</td>
                            <td class="text-end">
                                <form asp-action="Sil" method="post" style="display:inline;"
                                      onsubmit="return confirm('Bu notu silmek istediğinizden emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@not.Id" />
                                    <input type="hidden" name="ogrenciId" value="@ogrenci?.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" id="btnNotSil_@not.Id">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-journal-x"></i>
            <h5>Not Bulunamadı</h5>
            <p class="small">Bu öğrenciye henüz not girilmemiş.</p>
            <a asp-action="Ekle" asp-route-ogrenciId="@ogrenci?.Id" class="btn btn-success mt-2">
                <i class="bi bi-plus-circle me-2"></i>İlk Notu Ekle
            </a>
        </div>
    }
</div>
